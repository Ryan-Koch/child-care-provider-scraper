# Copy this file to `huggingface.env` and fill in your values to enable the
# Hugging Face upload step (run_spiders.sh -u). Use a WRITE token, and create
# the dataset repo on the Hugging Face website first.
#
#   cp huggingface.env.example huggingface.env
#
# The real huggingface.env is git-ignored and, under Docker, bind-mounted into
# the container read-only. It must exist for the compose mount to work, even if
# you don't use uploads — an empty copy is fine in that case.
hugging_face_token=hf_xxxxxxxx
hugging_face_repo=owner/dataset-name
