# Copy this file to `webshare.env` and fill in your values to enable the
# OPTIONAL multi-IP proxy pool for the Maryland spider. checkccmd.org caps
# throughput to ~2 requests/min per egress IP, so a run from one IP takes ~4-5
# days; N proxies each held to that cadence on their own slot gives ~Nx speed-up.
#
#   cp webshare.env.example webshare.env
#
# The real webshare.env is git-ignored. With it absent (or `-a proxies=off`), the
# spider runs in single-IP mode exactly as before — the pool is strictly opt-in.
#
# Values below are from a Webshare (https://www.webshare.io) free-tier account,
# which gives 4 US datacenter proxies. Any provider works: list its endpoints as
# comma-separated host:port (the username/password are shared across them). You
# can instead pass endpoints inline with `-a proxies="host:port,host:port"`, or
# embed credentials per endpoint as full `http://user:pass@host:port` URLs.
#
# This is public government data, so a proxy operator seeing the traffic is not a
# confidentiality concern — but never commit real credentials.
webshare_proxy_username=your-proxy-username
webshare_proxy_password=your-proxy-password
webshare_proxy_endpoints=host1:port1,host2:port2,host3:port3,host4:port4
